# Karios Deployment Validation Environment Configuration
# This file contains credentials for post-deployment testing

# Base URL for the deployed Karios instance
BASE_URL=https://192.168.113.103

# Deployment validation credentials
DEPLOY_TEST_USERNAME=admin
DEPLOY_TEST_PASSWORD=admin

# Test configuration
TEST_TIMEOUT=30000
VMTEST_TIMEOUT=60000
TEST_RETRIES=2

# Timeout configurations (in milliseconds)
